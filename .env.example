# Copiar este arquivo para .env.local e preencher com os valores do projeto nubo-hub
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# URL base do Cloudinha Agent (sem /chat — o service appende o path)
# Dev local:  http://localhost:8080
# Prod Cloud Run: https://cloudinha-agent-xxxxxx.southamerica-east1.run.app
NEXT_PUBLIC_CLOUDINHA_URL=http://localhost:8080
